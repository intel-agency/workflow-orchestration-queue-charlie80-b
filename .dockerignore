# .dockerignore - Files to exclude from Docker build context

# Git
.git
.gitignore

# Python
__pycache__
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
.venv/
venv/
ENV/
env/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# Type checking
.mypy_cache/

# Ruff
.ruff_cache/

# Environment files
.env
.env.local
.env.*.local

# Documentation
docs/
*.md
!README.md

# Plan documents
plan_docs/

# Scripts (not needed in container)
scripts/

# Test files
tests/
test/

# CI/CD
.github/
.gitlab-ci.yml
.travis.yml

# Docker
Dockerfile*
docker-compose*.yml
.dockerignore

# Other
*.log
*.tmp
.DS_Store
Thumbs.db
