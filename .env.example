# GitHub Token (required for both services)
GITHUB_TOKEN=your_github_token_here

# Webhook secret for GitHub App webhook verification
WEBHOOK_SECRET=your_webhook_secret_here

# Target repository configuration
GITHUB_ORG=intel-agency
GITHUB_REPO=workflow-orchestration-queue-charlie80-b

# Sentinel bot account login (for assign-then-verify locking)
# Must match the GitHub account the GITHUB_TOKEN authenticates as
SENTINEL_BOT_LOGIN=

# Polling interval in seconds (default: 60)
SENTINEL_POLL_INTERVAL=60
